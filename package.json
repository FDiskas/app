{
  "name": "applink",
  "version": "1.0.0",
  "main": "src/server/index.tsx",
  "type": "module",
  "scripts": {
    "dev:server": "bun --watch src/server/index.tsx",
    "dev:client": "vite --host",
    "db:migrate": "bun x prisma migrate dev",
    "dev": "bun x prisma generate && bun x prisma migrate deploy && concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "build": "vite build && prisma generate",
    "test": "bun test",
    "start": "bun x prisma migrate deploy && bun --smol src/server/index.tsx"
  },
  "dependencies": {
    "@orpc/client": "^1.14.2",
    "@orpc/server": "^1.14.2",
    "@orpc/tanstack-query": "^1.14.2",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.100.9",
    "dotenv": "^17.4.2",
    "google-play-scraper": "10.1.3",
    "hono": "^4.12.18",
    "lucide-react": "^0.479.0",
    "nanoid": "^5.1.11",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/bun": "^1.3.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^6.2.0"
  }
}