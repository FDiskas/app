generator client {
  provider = "prisma-client-js"
  output   = "./client"
}

datasource db {
  provider = "sqlite"
}

model ShortLink {
  id           String   @id @default(cuid())
  slug         String   @unique // e.g., "xY7z"
  androidId    String?
  androidName  String?
  androidIcon  String?
  iosId        String?
  iosName      String?
  iosIcon      String?
  gaId         String?  // Google Analytics tracking
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([androidId, iosId])
}
