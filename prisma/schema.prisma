generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum ShortLinkStatus {
  ACTIVE
  PARTIAL
}

model ShortLink {
  id           String   @id @default(cuid())
  slug         String   @unique // e.g., "xY7z"
  androidId    String?
  androidName  String?
  androidIcon  String?
  iosId        String?
  iosName      String?
  iosIcon      String?
  gaId         String?  // Google Analytics tracking
  status       ShortLinkStatus @default(ACTIVE)
  failCount    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([androidId, iosId])
}
